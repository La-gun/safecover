{
  "name": "safecover",
  "version": "1.0.0",
  "description": "SafeCover embedded microinsurance platform",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "cd backend && node server.js",
    "scenarios": "node scripts/launch-all-scenarios.js",
